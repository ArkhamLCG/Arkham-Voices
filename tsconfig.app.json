{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@app": ["src/slices/app/index.ts"],
      "@app/*": ["src/slices/app/*"],
      "@pages": ["src/slices/pages/index.ts"],
      "@pages/*": ["src/slices/pages/*"],
      "@widgets": ["src/slices/widgets/index.ts"],
      "@widgets/*": ["src/slices/widgets/*"],
      "@features": ["src/slices/features/index.ts"],
      "@features/*": ["src/slices/features/*"],
      "@entities": ["src/slices/entities/index.ts"],
      "@entities/*": ["src/slices/entities/*"],
      "@shared": ["src/slices/shared/index.ts"],
      "@shared/*": ["src/slices/shared/*"]
    },
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
