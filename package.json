{
  "name": "arkham-voices",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "biome check src cli",
    "format": "biome format --write src cli",
    "prepare": "lefthook install",
    "preview": "vite preview",
    "postinstall": "sh cli/sh/postinstall.sh",
    "icons": "tsx cli/init-icons.ts",
    "build:narration": "tsx cli/keep-narration.ts",
    "language:detect": "tsx cli/detect-languages.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "classnames": "^2.5.1",
    "dotenv": "^17.4.2",
    "i18next": "^26.0.6",
    "ramda": "^0.32.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^17.0.4",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/classnames": "^2.3.0",
    "@types/node": "^25.6.0",
    "@types/ramda": "^0.31.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "arkham-divider-data": "^1.3.0",
    "lefthook": "^1.13.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.4"
  }
}
